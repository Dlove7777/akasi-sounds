# Foley reads these from the environment (dev loads them from ~/.secrets.env automatically).
# Freesound is the primary online seed source. Get a free key: https://freesound.org/apiv2/apply/
FREESOUND_API_KEY=

# Pixabay: only images/video are exposed via API — no official audio endpoint — so this
# is reserved for a future site-scrape provider, not used by V1.
PIXABAY_API_KEY=
